root = true

[*.cs]
indent_style = space
indent_size = 4

# Collection expressions (C# 12+) — enforce `[...]` over `.ToList()`, `.ToArray()`,
# `new List<T> { ... }`, `Array.Empty<T>()`, `ImmutableArray.Create(...)`, etc.
# Builds the same collection with less ceremony and lets the compiler pick the
# optimal allocation. Treated as errors so the rule is non-negotiable.
dotnet_style_prefer_collection_expression = when_types_loosely_match:error
dotnet_diagnostic.IDE0300.severity = error  # Use collection expression for array
dotnet_diagnostic.IDE0301.severity = error  # Use collection expression for empty
dotnet_diagnostic.IDE0302.severity = error  # Use collection expression for stackalloc
dotnet_diagnostic.IDE0303.severity = error  # Use collection expression for Create()
dotnet_diagnostic.IDE0304.severity = error  # Use collection expression for builder
dotnet_diagnostic.IDE0305.severity = error  # Use collection expression for fluent (.ToList/.ToArray)
dotnet_diagnostic.IDE0306.severity = error  # Use collection expression for new

# AssemblyReference.cs files exist solely as type markers so each
# layer can reference its assembly via `typeof(AssemblyReference).Assembly`
# (architecture tests, handler registration, etc.).
# S2094 ("Remove this empty class, write its code or make it an interface")
# is a false positive for this established DDD pattern.
[**/AssemblyReference.cs]
dotnet_diagnostic.S2094.severity = none

# EF Core generates migration files (and the model snapshot) with patterns like
# `new[] { ... }` that the collection-expression analyzers flag. These files are
# tool-generated, not hand-written, so the style gate does not apply to them.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.IDE0300.severity = none
dotnet_diagnostic.IDE0301.severity = none
dotnet_diagnostic.IDE0302.severity = none
dotnet_diagnostic.IDE0303.severity = none
dotnet_diagnostic.IDE0304.severity = none
dotnet_diagnostic.IDE0305.severity = none
dotnet_diagnostic.IDE0306.severity = none

[*.{ts,tsx,js,jsx,json,yml,yaml}]
indent_style = space
indent_size = 2
