---
import { url } from '../lib/url'

const links = [
  { href: url('/docs/introduction'), label: 'Docs' },
  { href: url('/registry'), label: 'Registry' },
  { href: url('/pricing'), label: 'Pricing' },
  { href: url('/cloud'), label: 'Outlet Cloud' },
]
---

<header class="sticky top-0 z-40 w-full border-b border-border bg-background/90 backdrop-blur">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
    <div class="flex items-center gap-8">
      <a href={url('/')} class="flex items-center gap-2 font-semibold tracking-tight">
        <span class="grid h-6 w-6 place-items-center rounded-md bg-primary font-mono text-xs font-bold text-primary-foreground">O</span>
        Outlet
      </a>
      <nav class="hidden items-center gap-6 text-sm sm:flex">
        {links.map((l) => (
          <a href={l.href} class="text-muted-foreground transition-colors hover:text-foreground">{l.label}</a>
        ))}
      </nav>
    </div>
    <div class="flex items-center gap-3 text-sm">
      <a
        href="https://github.com/Leroy-Florian/Outlet-CLI"
        class="text-muted-foreground transition-colors hover:text-foreground"
      >
        GitHub
      </a>
      <a
        href={url('/cloud#early-access')}
        class="rounded-md bg-primary px-3 py-1.5 font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        Get early access
      </a>
    </div>
  </div>
</header>
