## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Mutation testing
StrykerOutput/

# Node / frontend
node_modules/
packages/*/dist/
*.tsbuildinfo
coverage/
.turbo/

# Generated registry manifest: dist/registry/ is tracked (published artefact),
# anything else under dist/ is build output. Order matters: the un-ignore must
# target a directory whose parent is not itself excluded (hence dist/* not dist/).
dist/*
!dist/registry/

# Local dotnet tool pack output
/nupkg/

# Playground web build output
playground/web/dist/

# Frontend build output
playground/*/dist/

# Local SQLite demo databases (Outlet:UseSqlite=true)
*.db

# Local demo runtime artifacts
*.log
outlet_*.db*
